<group name="orbit,local,">
  <rule id="100100" level="0">
    <decoded_as>json</decoded_as>
    <field name="orbit_source">ORBIT</field>
    <field name="orbit_type">actioncard_pending</field>
    <description>ORBIT ActionCard base event</description>
    <options>no_full_log</options>
  </rule>

  <rule id="100101" level="5">
    <if_sid>100100</if_sid>
    <field name="priority">LOW</field>
    <description>ORBIT LOW ActionCard $(orbit_action_id) for $(affected_host)</description>
    <group>orbit,actioncard,</group>
  </rule>

  <rule id="100102" level="8">
    <if_sid>100100</if_sid>
    <field name="priority">MEDIUM</field>
    <description>ORBIT MEDIUM ActionCard $(orbit_action_id) for $(affected_host)</description>
    <group>orbit,actioncard,</group>
  </rule>

  <rule id="100103" level="12">
    <if_sid>100100</if_sid>
    <field name="priority">HIGH</field>
    <description>ORBIT HIGH ActionCard $(orbit_action_id) for $(affected_host)</description>
    <group>orbit,actioncard,</group>
  </rule>

  <rule id="100104" level="14">
    <if_sid>100100</if_sid>
    <field name="priority">CRITICAL</field>
    <description>ORBIT CRITICAL ActionCard $(orbit_action_id) for $(affected_host)</description>
    <group>orbit,actioncard,</group>
  </rule>
</group>
