# ─────────────────────────────────────────────
# ORBIT Node — Environment Variables
# Copy to .env and fill in real values.
# ─────────────────────────────────────────────

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# Presidio Analyzer
PRESIDIO_URL=http://localhost:5001

# ORC thresholds
CROWN_JEWEL_THRESHOLD=0.75
