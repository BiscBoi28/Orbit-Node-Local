# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default
KEY_PAIR_NAME=
# Path to SSH private key for Ansible (e.g. .pem used when launching EC2). Leave empty if using SSM or no key.
SSH_PRIVATE_KEY_FILE=
# Use AWS Systems Manager for Ansible (no SSH key). Set to true when instances have no key pair.
USE_SSM=true
# S3 bucket for SSM file transfer (required when USE_SSM=true). Create a bucket in the same account/region and set its name here.
SSM_BUCKET_NAME=
ADMIN_CIDR=0.0.0.0/0

# Stack names
PRE_REQ_STACK=njsecure-prod-pre-requirements
SECRETS_STACK=njsecure-prod-secrets
EC2_STACK_PREFIX=njsecure-prod-ec2

# Wazuh
WAZUH_SERVER_IP=44.194.78.195
WAZUH_SERVER_PORT=1514
WAZUH_AGENT_GROUP=bank-simulation

# Project
PROJECT=ORBIT
ENVIRONMENT=simulation
CSV_FILE=../ORBIT_simulated_bank.csv
